# Server Configuration
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/?appName=YourApp
MONGODB_DB=certificate_registry

# Authentication
JWT_SECRET=<generate-with: openssl rand -hex 64>

# Blockchain (Sepolia or Polygon)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ISSUER_PRIVATE_KEY=0x<your-deployer-wallet-private-key>
CERTIFICATE_CONTRACT_ADDRESS=0x<deployed-contract-address>

# Pinata IPFS
PINATA_JWT=<your-pinata-jwt-token>
PINATA_GATEWAY_URL=<your-pinata-gateway-subdomain>.mypinata.cloud

# Verification URL (public URL where users verify certs)
PUBLIC_VERIFY_URL=http://localhost:5173/verify

# Admin Seed (used for initial setup only)
SEED_ADMIN_NAME=Platform Admin
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=<strong-password>
SEED_ORGANIZATION_ID=org-001
SEED_ADMIN_WALLET=
